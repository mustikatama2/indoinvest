# IndoInvest environment variables
# Copy to .env.local for local dev, or set in Vercel project settings

# Supabase — required for DB-first snapshot/manual-value persistence
# Get from: https://app.supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Note: these are SERVER-SIDE only (used by api/ serverless functions).
# Never expose the service key to the browser.
